# GoAlgo SEO — 首版策略：公开分享页一律 SEO HTML（不靠 UA）
# Requires backend: GET /v1/user/seo/html（X-Original-URI）+ /v1/user/seo/sitemap.xml
# Replace 127.0.0.1:8080 with your API gateway.

location = /robots.txt {
  try_files /robots.txt =404;
}

location = /sitemap.xml {
  proxy_pass http://127.0.0.1:8080/v1/user/seo/sitemap.xml;
  proxy_set_header Host $host;
  proxy_set_header X-Forwarded-Proto https;
  proxy_set_header X-Forwarded-Host $host;
}

# Blog admin stays SPA
location ~ ^/blog/[^/]+/manage {
  try_files $uri $uri/ /index.html;
}

location ~ ^/problemset/[^/]+/add-problem {
  try_files $uri $uri/ /index.html;
}

# 一律 SEO（path 用 X-Original-URI，勿塞进 ?path= 以免 query 被截断）
location ~ ^/blog/ {
  proxy_pass http://127.0.0.1:8080/v1/user/seo/html;
  proxy_set_header Host $host;
  proxy_set_header X-Forwarded-Proto https;
  proxy_set_header X-Forwarded-Host $host;
  proxy_set_header X-Original-URI $request_uri;
}

location ~ ^/question-bank/detail/ {
  proxy_pass http://127.0.0.1:8080/v1/user/seo/html;
  proxy_set_header Host $host;
  proxy_set_header X-Forwarded-Proto https;
  proxy_set_header X-Forwarded-Host $host;
  proxy_set_header X-Original-URI $request_uri;
}

location ~ ^/problemset {
  proxy_pass http://127.0.0.1:8080/v1/user/seo/html;
