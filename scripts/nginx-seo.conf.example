location ~ ^/profile {
  proxy_pass http://127.0.0.1:8080/v1/user/seo/html;
  proxy_set_header Host $host;
  proxy_set_header X-Forwarded-Proto https;
  proxy_set_header X-Forwarded-Host $host;
  proxy_set_header X-Original-URI $request_uri;
}

location = /blog-plaza {
  proxy_pass http://127.0.0.1:8080/v1/user/seo/html;
